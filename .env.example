# Copie para .env e preencha. NUNCA comite o .env real.

# Chave secreta do Flask (gere uma aleatória, ex: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque-esta-chave

# Banco de dados.
# Dev: deixe em branco para usar SQLite local (app.db).
# Prod: cole a connection string do Postgres da Supabase, ex:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=

# Ambiente: development ou production
FLASK_ENV=development
